{#
/**
 * Minimal "title + date" rendering for use inside related-publications
 * card-collection grid. Heading falls back to label when no teaser title.
 *
 * Available Variables:
 * - date_formatted: ISO 8601 publish date (set by atomic_preprocess_node__resource).
 *
 * @see atomic_preprocess_node__resource()
 */
#}

{% set heading = content.field_teaser_title.0 ? content.field_teaser_title : label %}

{% set date_str %}
  {% if date_formatted %}
    {% include "@atoms/date-time/yds-date-time.twig" with {
      date_time__start: date_formatted,
      date_time__format: 'date',
    } %}
  {% endif %}
{% endset %}

{% include "@molecules/cards/reference-card/yds-reference-card.twig" with {
  reference_card__heading: heading,
  reference_card__url: url,
  reference_card__subheading: date_str,
  reference_card__image: 'false',
} %}
