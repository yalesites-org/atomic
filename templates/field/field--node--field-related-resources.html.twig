{#
/**
 * Wraps Resource related-resources output in a card-collection grid.
 * Each child renders via the title_date view mode (a single <li>
 * reference-card with title + date), and we wrap them in the
 * card-collection organism for the responsive 1→2→3-up grid + heading.
 */
#}

{% if items %}
  {% embed "@organisms/card-collection/yds-card-collection.twig" with {
    card_collection__heading: 'Related Content'|t,
    card_collection__type: 'grid',
    card_collection__featured: 'true',
    card_collection__modifiers: ['related'],
  } %}
    {% block card_collection__cards %}
      {% for item in items %}
        {{ item.content }}
      {% endfor %}
    {% endblock %}
  {% endembed %}
{% endif %}
