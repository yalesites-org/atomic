                  <span {{ bem('copy-label', [], colors__base_class) }}>Copy {{ label }} {{ val }}</span>
                </button>
              </div>
            {% endfor %}
          </div>
        </li>
      {% endfor %}
    </ul>
    </div>
  </section>
{% endfor %}
