<ul {{ bem('taxonomy-list', ['tags'], '') }}>
  {% for item in items %}
    <li {{ bem('item', [], 'taxonomy-list') }}>
      {% block list_item %}
        {{ item.content }}
      {% endblock %}
    </li>
    <li aria-hidden="true" {{ bem('divider', [], 'taxonomy-list') }}>{{ '|' }}</li>
  {% endfor %}
</ul>
